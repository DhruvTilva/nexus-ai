# ========================
# NexusAI Configuration
# ========================

# Server
PORT=3000
NODE_ENV=production

# Authentication
ALLOWED_API_KEYS=mykey1,mykey2,mykey3
ADMIN_PASSWORD=supersecretadmin123

# Cache (Upstash Redis) — Get free at https://upstash.com
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-token

# Provider API Keys
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key
HUGGINGFACE_API_KEY=your-hf-key
COHERE_API_KEY=your-cohere-key
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
CLOUDFLARE_API_TOKEN=your-cf-token
OPENROUTER_API_KEY=your-openrouter-key
OLLAMA_HOST=http://localhost:11434

# Routing Config
PROVIDER_TIMEOUT_MS=5000
MAX_RETRIES=3
HEALTH_COOLDOWN_MINUTES=5

# Cache Config
DEFAULT_CACHE_TTL_SECONDS=86400
FACTUAL_CACHE_TTL_SECONDS=604800
TIMESENSITIVE_CACHE_TTL_SECONDS=3600
